{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native"
  },
  "include": [
    "App.tsx",
    "index.ts",
    "screens/**/*.ts",
    "screens/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "contexts/**/*.ts",
    "contexts/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "gerenciador"
  ]
}
